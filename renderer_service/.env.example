# Copy to .env for local development. All values shown are the defaults
# the service already falls back to if unset — this file exists for
# discoverability and for production deployments to override.

APP_NAME=ArchPresent Renderer Service
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false

LOG_LEVEL=INFO
LOG_FORMAT=text

HOST=0.0.0.0
PORT=8000

# Comma-separated list of origins allowed to call this service.
CORS_ALLOW_ORIGINS=http://localhost:3000

MAX_UPLOAD_SIZE_MB=20
REQUEST_TIMEOUT_SECONDS=30
