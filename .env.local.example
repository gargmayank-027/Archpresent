# ─────────────────────────────────────────────────────────────────────────────
# ArchPresent — Environment Variables
# Copy to .env.local, fill in values, restart: npm run dev
# ─────────────────────────────────────────────────────────────────────────────

APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# MOODBOARD "FIRST DRAFT" — Unsplash (real, sourceable interior photos)
# ─────────────────────────────────────────────────────────────────────────────
#
# This is the Pinterest-style workflow: real, buildable photography rather
# than AI-hallucinated furniture. Pinterest has no public search API, so
# Unsplash is the closest legitimate equivalent — genuine photographer-
# credited interior photos, fully free.
#
#   1. Go to unsplash.com/developers -> "New Application"
#   2. Accept the API terms, name it "ArchPresent"
#   3. Copy the "Access Key" (not the Secret Key)
#   4. Paste below
#
# Free tier: 50 requests/hour. Each room load / "try another" uses one
# request; results are cached 5 minutes to stretch this further. Without
# this key, the app falls back straight to AI-generated images.
#
UNSPLASH_ACCESS_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# MOODBOARD AI GENERATION — Pollinations.ai (FREE)
# Used per-image when an architect clicks "Generate with AI" instead of a
# real photo, or as the fallback if Unsplash isn't configured / has no results.
# ─────────────────────────────────────────────────────────────────────────────
#
# Works with NO key at all, but Pollinations' unauthenticated requests share
# a single global queue that gets overloaded ("Queue full") during busy
# periods. A free API key fixes this — no credit card needed:
#
#   1. Go to enter.pollinations.ai
#   2. Sign in with GitHub (free, 30 seconds)
#   3. Create a key (publishable "pk_" is fine for this app)
#   4. Paste it below
#
# What you get:
#   - Real AI-generated interior images (FLUX model)
#   - 3-4 images per room (wide shot, detail, atmosphere, close-up)
#   - 4-image overall style collage
#   - With a key: reliable, no queue errors. Without: works, but may need retries.
#
POLLINATIONS_API_KEY=pk_...

# If you want a paid alternative instead (faster / higher quality), set
# REPLICATE_API_TOKEN below — it's used automatically as a fallback if
# Pollinations is ever unreachable.

# ─────────────────────────────────────────────────────────────────────────────
# PLAN ANALYSIS — Google Gemini Flash (FREE)
# ─────────────────────────────────────────────────────────────────────────────
#
# Setup (1 minute):
#   1. Go to aistudio.google.com
#   2. Click "Get API Key" → "Create API key in new project"
#   3. Copy the key (starts with AIza)
#
GOOGLE_AI_KEY=AIza...

# ─────────────────────────────────────────────────────────────────────────────
# VERCEL STORAGE (production only — added by: vercel env pull .env.local)
# ─────────────────────────────────────────────────────────────────────────────

BLOB_READ_WRITE_TOKEN=
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# PAID FALLBACKS (optional — only used if Pollinations is unreachable)
# ─────────────────────────────────────────────────────────────────────────────

# Anthropic Claude (plan analysis fallback) — ~$0.03/analysis
ANTHROPIC_API_KEY=

# OpenAI GPT-4o + DALL-E 3 (analysis + image fallback) — ~$0.04/analysis, $0.04/image
OPENAI_API_KEY=

# Replicate FLUX (image generation fallback) — ~$0.003/image, faster than free tiers
REPLICATE_API_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# PLAN ENHANCEMENT
# ─────────────────────────────────────────────────────────────────────────────
# Sharp runs locally — no key needed, always free.
# Set false to skip (useful if Sharp isn't installed)
ENABLE_PLAN_ENHANCEMENT=true
