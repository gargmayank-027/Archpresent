# ─── App ─────────────────────────────────────────────────────────────────────
# Used to build absolute image URLs for AI vision calls.
# In production, set this to your deployed domain.
APP_URL=http://localhost:3000

# ─── AI — Multimodal plan analysis (plug in when ready) ──────────────────────
# Option A: OpenAI GPT-4o
OPENAI_API_KEY=sk-...

# Option B: Anthropic Claude 3.5 Sonnet
ANTHROPIC_API_KEY=sk-ant-...

# ─── AI — Image generation for moodboards ────────────────────────────────────
# Option A: Replicate (FLUX.1-schnell or SDXL)
REPLICATE_API_TOKEN=r8_...

# Option B: fal.ai
FAL_KEY=...

# Option C: OpenAI DALL-E 3
# (uses the same OPENAI_API_KEY above)

# ─── Storage (future) ─────────────────────────────────────────────────────────
# When you outgrow local disk storage, swap saveUploadedFile() in lib/store.ts
# for an S3/R2 implementation and set these:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-south-1
# S3_BUCKET_NAME=archpresent-uploads
